{
  "manifest_version": 3,
  "name": "LinkedIn Games Solver",
  "version": "1.1",
  "description": "Résout automatiquement Queens et Mini Sudoku de LinkedIn",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Games Solver"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/games/queens/*",
        "https://www.linkedin.com/games/mini-sudoku/*",
        "https://www.linkedin.com/games/tango/*",
        "https://www.linkedin.com/games/zip/*",
        "https://www.linkedin.com/games/patches/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
